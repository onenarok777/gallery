# Database
# Local: postgres://gallery_admin:gallery_password@127.0.0.1:5432/gallery_db
# Docker: postgres://gallery_admin:gallery_password@postgres:5432/gallery_db
DATABASE_URL="postgres://gallery_admin:gallery_password@127.0.0.1:5432/gallery_db"

# API Settings
# NEXT_PUBLIC_API_URL: Publicly accessible URL for the browser
# NEXT_PUBLIC_SITE_URL: Publicly accessible URL of the frontend (for webhooks)
PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google Drive API
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# Face Search Service (Port 5001)
# Local: http://127.0.0.1:5001
# Docker: http://face-service:5001
FACE_SERVICE_URL="http://localhost:5001"
FACE_SERVICE_API_KEY=""

# S3 Storage Configuration
S3_BUCKET="your-bucket-name"
S3_REGION="auto"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_ENDPOINT="https://your-r2-endpoint.cloudflarestorage.com"
S3_PUBLIC_URL="https://pub-your-id.r2.dev"

# Security / Webhooks / Cron
REVALIDATE_SECRET="your_revalidate_secret_here"
CRON_SECRET="your_cron_secret_here"

# Google Drive API Additional
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"
