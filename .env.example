# ===========================================
# Gallery Application - Environment Variables
# ===========================================

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ---------- Database ----------
# Local: postgres://gallery_admin:gallery_password@127.0.0.1:5432/gallery_db
# Docker: postgres://gallery_admin:gallery_password@postgres:5432/gallery_db
DATABASE_URL="postgres://gallery_admin:gallery_password@127.0.0.1:5432/gallery_db"

# ---------- Google OAuth (Admin Login) ----------
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# ---------- Google Drive API (Service Account) ----------
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------- Auth / JWT ----------
JWT_SECRET="your-jwt-secret-here"

# ---------- Face Search Service ----------
# Local: http://localhost:5001
# Docker: http://face-service:5001
FACE_SERVICE_URL="http://localhost:5001"
FACE_SERVICE_API_KEY="your-face-service-api-key"

# ---------- S3 / Cloudflare R2 Storage ----------
S3_BUCKET="your-bucket-name"
S3_REGION="auto"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_ENDPOINT="https://your-r2-endpoint.cloudflarestorage.com"
S3_PUBLIC_URL="https://pub-your-id.r2.dev"

# ---------- Security / Webhooks / Cron ----------
REVALIDATE_SECRET="your-revalidate-secret"
CRON_SECRET="your-cron-secret"