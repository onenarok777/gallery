{
  "name": "@gallery/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "build": "dotenv -e ../../.env -- esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "r2:setup-cors": "tsx src/scripts/setup-r2-cors.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "@hono/node-server": "^1.13.7",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "hono": "^4.6.14",
    "postgres": "^3.4.8",
    "snowflake-id": "^1.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}
